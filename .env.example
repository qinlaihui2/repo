# 复制为 .env.local 后按需填写

# 后端 API 根地址（不要末尾斜杠）
# 本地开发可写 http://localhost:8080；不设时生产构建会默认走 Railway 线上地址
# NEXT_PUBLIC_API_BASE_URL=https://my-block-backend-production.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 站点绝对 URL，用于 metadata / 分享链接（可选；Vercel 可不填，会用 VERCEL_URL）
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
